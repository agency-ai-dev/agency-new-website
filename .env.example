# beehiiv newsletter signup — used by api/subscribe.js
#
# Set the real values in the Vercel project (Settings > Environment Variables)
# and store a copy in the password manager. Never commit them.
#
# Both are found in beehiiv under Settings > Integrations.

BEEHIIV_API_KEY=
BEEHIIV_PUB_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
